# =============================================================================
# .gitignore — Wings-Infer 推理服务平台
# =============================================================================

# ---- Python 编译缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Python 打包 ----
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl

# ---- 虚拟环境 ----
.venv/
venv/
env/
ENV/

# ---- IDE / 编辑器 ----
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# ---- OS 临时文件 ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- 日志与运行时 ----
*.log
*.pid
*.sock
nohup.out

# ---- 测试覆盖率 ----
.coverage
htmlcov/
.pytest_cache/
.tox/
.nox/

# ---- 模型权重（通常很大，不应入库）----
*.bin
*.safetensors
*.gguf
*.ckpt
*.pt
*.pth
model_weights/

# ---- Docker / K8s 临时文件 ----
*.tar
*.tar.gz

# ---- 环境变量文件（可能含敏感信息）----
.env
.env.local
.env.*.local

# ---- Ray / 分布式运行时 ----
/tmp/ray/
ray_results/

# ---- Jupyter ----
.ipynb_checkpoints/
