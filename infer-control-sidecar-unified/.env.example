# =============================================================================
# Wings-Infer 统一 Sidecar 环境变量模板
# 复制为 .env 并根据部署场景调整参数
#
# 变量说明:
#   ENGINE         - 推理引擎类型 (vllm|vllm_ascend|sglang|mindie)
#   MODEL_NAME     - 模型名称
#   MODEL_PATH     - 模型权重存储路径
#   ENGINE_PORT    - 引擎监听端口 (17000)
#   PORT           - Proxy 监听端口 (18000)
#   HEALTH_PORT    - Health 监听端口 (19000)
#   DISTRIBUTED    - 启用分布式模式 (true|false)
# ============================================================

# ---- Engine ----
# Supported: vllm | vllm_ascend | sglang | mindie
ENGINE=vllm

# ---- Model ----
MODEL_NAME=DeepSeek-R1-Distill-Qwen-1.5B
MODEL_PATH=/models/DeepSeek-R1-Distill-Qwen-1.5B

# ---- Ports ----
ENGINE_PORT=17000
PORT=18000
HEALTH_PORT=19000

# ---- Proxy / backend ----
BACKEND_URL=http://127.0.0.1:17000
WINGS_SKIP_PID_CHECK=true

# ---- Hardware (optional) ----
# WINGS_DEVICE=ascend
# DEVICE=ascend
# ASCEND_VISIBLE_DEVICES=0,1
# NVIDIA_VISIBLE_DEVICES=all

# ---- Distributed (optional) ----
# DISTRIBUTED=true
# NNODES=2
# NODE_RANK=0
# HEAD_NODE_ADDR=192.168.1.100
# NODE_IPS=192.168.1.100,192.168.1.101
# DISTRIBUTED_EXECUTOR_BACKEND=ray

# ---- vLLM / vLLM-Ascend ----
# TENSOR_PARALLEL_SIZE=2
# MAX_MODEL_LEN=4096
# GPU_MEMORY_UTILIZATION=0.9
# DTYPE=auto
# TRUST_REMOTE_CODE=true

# ---- SGLang ----
# TP_SIZE=1
# CONTEXT_LENGTH=4096

# ---- MindIE ----
# MINDIE_CONFIG_PATH=/opt/config/config.json

# ---- Health tuning ----
# HEALTH_CHECK_INTERVAL=5
# HEALTH_CHECK_TIMEOUT=3
# STARTUP_GRACE_MS=3600000
# POLL_INTERVAL_MS=5000
# HEALTH_TIMEOUT_MS=5000
# FAIL_THRESHOLD=5

# ---- MindIE health probe ----
# MINDIE_HEALTH_HOST=127.0.0.2
# MINDIE_HEALTH_PORT=1026

# ---- Stable network defaults for chat streaming ----
HTTP2_ENABLED=false
HTTPX_MAX_CONNECTIONS=256
HTTPX_MAX_KEEPALIVE=64
HTTPX_KEEPALIVE_EXPIRY=20
HTTPX_CONNECT_TIMEOUT=20
HTTPX_WRITE_TIMEOUT=20
HTTPX_POOL_TIMEOUT=30
RETRY_TRIES=5
RETRY_INTERVAL_MS=300
STREAM_BACKEND_CONNECT_TIMEOUT=20
METRICS_CONNECT_TIMEOUT=10
STATUS_CONNECT_TIMEOUT=10
STATUS_READ_TIMEOUT=30
QUEUE_TIMEOUT=30

# ---- Other tuning ----
# HTTP_CLIENT_TIMEOUT=300
# WARMUP_REQUEST_TIMEOUT=300
# BACKEND_PID_FILE=/var/log/wings/wings.txt
# OMP_NUM_THREADS=100
# PROXY_WORKERS=1
# NPU_MAX_SPLIT_SIZE_MB=256

# ---- Distributed ports ----
# RAY_PORT=6379
# SGLANG_DIST_PORT=28030
# VLLM_DP_RPC_PORT=13355
# MINDIE_MASTER_PORT=27070
# PD_KV_PORT=20001

# ---- Network interfaces (distributed) ----
# NCCL_SOCKET_IFNAME=eth0
# HCCL_SOCKET_IFNAME=eth0
# GLOO_SOCKET_IFNAME=eth0

# ---- KV cache libs (vLLM) ----
# KV_AGENT_LIB_PATH=/usr/local/lib/kv_agent.so
# LMCACHE_LIB_PATH=/usr/local/lib/liblmcache_vllm.so
